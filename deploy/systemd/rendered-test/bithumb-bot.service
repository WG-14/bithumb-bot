[Unit]
Description=Bithumb bot trading loop (live)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/mnt/c/dev/bithumb-bot
Environment=BITHUMB_ENV_FILE=/etc/bithumb-bot/bithumb-bot.live.env
ExecStart=/usr/bin/env bash -lc 'uv run python -m bithumb_bot run --mode live --short ${SMA_SHORT:-7} --long ${SMA_LONG:-30}'
Restart=always
RestartSec=5
SyslogIdentifier=bithumb-bot-live
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
