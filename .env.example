# Core runtime
MODE=paper
ENV_ROOT=/var/lib/bithumb-bot/env
RUN_ROOT=/var/lib/bithumb-bot/run
DATA_ROOT=/var/lib/bithumb-bot/data
LOG_ROOT=/var/lib/bithumb-bot/logs
BACKUP_ROOT=/var/lib/bithumb-bot/backup
# optional
ARCHIVE_ROOT=/var/lib/bithumb-bot/archive
# Storage contract quick map (PathManager-managed):
# - logs/<mode>/{app,strategy,orders,fills,errors,audit}
# - data/<mode>/trades/*        (append-only ledger JSONL + sqlite)
# - data/<mode>/reports/*       (ops/validation/diagnostics/recovery JSON)
# - data/<mode>/derived/*       (analysis/trace/tuning artifacts)
# - data/<mode>/raw/*           (future API raw response archives)
PAIR=BTC_KRW
INTERVAL=1m
EVERY=60
# Migration note:
# - 운영 기본값은 sma_with_filter로 전환됨 (수수료/슬리피지 현실 반영)
# - 이전 동작으로 되돌리려면 STRATEGY_NAME=sma_cross 로 override
# - STRATEGY_NAME 값은 공백/대소문자와 무관하게 정규화됨
STRATEGY_NAME=sma_with_filter
SMA_SHORT=7
SMA_LONG=30
SMA_FILTER_GAP_MIN_RATIO=0.0012
SMA_FILTER_VOL_WINDOW=10
SMA_FILTER_VOL_MIN_RANGE_RATIO=0.003
SMA_FILTER_OVEREXT_LOOKBACK=3
SMA_FILTER_OVEREXT_MAX_RETURN_RATIO=0.02
ENTRY_EDGE_BUFFER_RATIO=0.0005
STRATEGY_MIN_EXPECTED_EDGE_RATIO=0
STRATEGY_EXIT_RULES=opposite_cross,max_holding_time
STRATEGY_EXIT_MAX_HOLDING_MIN=0
# 청산 이익 바닥 필터(0이면 비용 기반 바닥값 사용).
# AWS/ECS/EC2 배포에서는 코드 수정 없이 환경변수 override만으로 즉시 제어 가능.
STRATEGY_EXIT_MIN_TAKE_PROFIT_RATIO=0
# 0이면 min_profit_floor(max(STRATEGY_EXIT_MIN_TAKE_PROFIT_RATIO, 2*LIVE_FEE_RATE_ESTIMATE))를 손실 완충에도 동일 적용
STRATEGY_EXIT_SMALL_LOSS_TOLERANCE_RATIO=0
# Optional compatibility override:
# - If unset, defaults to DATA_ROOT/<mode>/trades/<mode>.sqlite
DB_PATH=
# Optional compatibility override:
# - If unset, defaults to RUN_ROOT/<mode>/bithumb-bot.lock
RUN_LOCK_PATH=
# Optional compatibility override (legacy):
# - If unset, backup script uses BACKUP_ROOT/<mode>/db
# - New runtime snapshots default to BACKUP_ROOT/<mode>/snapshots
SNAPSHOT_ROOT=

# Notifier (set at least one)
NOTIFIER_ENABLED=true
NOTIFIER_TIMEOUT_SEC=5
NOTIFIER_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Healthcheck threshold
HEALTH_MAX_CANDLE_AGE_SEC=180
HEALTH_MAX_ERROR_COUNT=3

# Backup policy
# - BACKUP_DIR is legacy compatibility override.
# - If unset, BACKUP_ROOT/<mode>/db is used.
BACKUP_DIR=
BACKUP_RETENTION_DAYS=7
BACKUP_RETENTION_COUNT=30

# Trading risk limits (required in live mode; must be > 0)
# Conservative profile for a small 1,000,000 KRW account:
# - MAX_ORDER_KRW: 30,000 (about 3% per order)
# - MAX_DAILY_LOSS_KRW: 20,000 (about 2% daily loss cap)
# - MAX_DAILY_ORDER_COUNT: 6 (limits over-trading)
MAX_ORDER_KRW=30000
MAX_DAILY_LOSS_KRW=20000
MAX_DAILY_ORDER_COUNT=6

# Related live safety switches
KILL_SWITCH=false
# Keep false for normal operation.
# If true, kill switch handling will also attempt position flattening.
# This is not a live preflight failure by itself.
KILL_SWITCH_LIQUIDATE=false

# Live execution safety
# Keep true during first live bring-up / post-change validation.
LIVE_DRY_RUN=true
BITHUMB_API_KEY=
BITHUMB_API_SECRET=

# Fee configuration
# - LIVE_FEE_RATE_ESTIMATE: live 주문 전 사전판단(현금/잔고 보호) 전용 보수적 수수료 추정치
# - PAPER_FEE_RATE: paper 체결/손익 시뮬레이션 전용 수수료율
# - 전략 비용 필터는 LIVE_FEE_RATE_ESTIMATE + STRATEGY_ENTRY_SLIPPAGE_BPS + ENTRY_EDGE_BUFFER_RATIO 를 함께 사용
# - STRATEGY_MIN_EXPECTED_EDGE_RATIO로 기대 엣지 하한선을 추가 제어
# Backward compatibility:
# - If LIVE_FEE_RATE_ESTIMATE is unset, FEE_RATE(legacy) -> 0.0025 순서로 fallback
# - If PAPER_FEE_RATE is unset, PAPER_FEE_RATE_ESTIMATE(legacy) -> FEE_RATE(legacy) -> LIVE_FEE_RATE_ESTIMATE -> 0.0025 순서로 fallback
LIVE_FEE_RATE_ESTIMATE=0.0025
PAPER_FEE_RATE=0.0025

# Live orderbook / market slippage protections
# In MODE=live, set both to finite values > 0.
MAX_ORDERBOOK_SPREAD_BPS=0
MAX_MARKET_SLIPPAGE_BPS=0
# 전략 진입 비용 필터용 예상 슬리피지(bps).
# 미설정 시 MAX_MARKET_SLIPPAGE_BPS -> SLIPPAGE_BPS -> 0 순서로 fallback.
STRATEGY_ENTRY_SLIPPAGE_BPS=0

# Additional live price protection.
# Template defaults keep 0 for backward compatibility, but in MODE=live
# you must override LIVE_PRICE_PROTECTION_MAX_SLIPPAGE_BPS to a finite value > 0.
# - blocks BUY if best ask is above reference + slippage threshold
# - blocks SELL if best bid is below reference - slippage threshold
# - when LIVE_PRICE_REFERENCE_MAX_AGE_SEC > 0, stale/unknown reference age blocks submission
LIVE_PRICE_PROTECTION_MAX_SLIPPAGE_BPS=0
LIVE_PRICE_REFERENCE_MAX_AGE_SEC=0

# Optional live order quantity normalization (safe/no-op defaults)
# - applied by flooring only (never rounds up)
LIVE_MIN_ORDER_QTY=0
LIVE_ORDER_QTY_STEP=0
LIVE_ORDER_MAX_QTY_DECIMALS=0

# ------------------------------------------------------------
# Conservative preset examples (small-account, safety-first)
# Copy one block into your runtime env file and adjust webhook/API values.
# Keep paper/live DB paths separated to avoid ledger mixing.
# ------------------------------------------------------------

# [Preset A] Paper validation (recommended first step)
# MODE=paper
# ENV_ROOT=/var/lib/bithumb-bot/env
# RUN_ROOT=/var/lib/bithumb-bot/run
# DATA_ROOT=/var/lib/bithumb-bot/data
# LOG_ROOT=/var/lib/bithumb-bot/logs
# BACKUP_ROOT=/var/lib/bithumb-bot/backup
# DB_PATH=/var/lib/bithumb-bot/data/paper/trades/paper.sqlite
# NOTIFIER_ENABLED=true
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# MAX_ORDER_KRW=30000
# MAX_DAILY_LOSS_KRW=20000
# MAX_DAILY_ORDER_COUNT=6
# KILL_SWITCH=false
# KILL_SWITCH_LIQUIDATE=false
# LIVE_DRY_RUN=true

# [Preset B] Live dry-run (no real order API calls)
# MODE=live
# ENV_ROOT=/var/lib/bithumb-bot/env
# RUN_ROOT=/var/lib/bithumb-bot/run
# DATA_ROOT=/var/lib/bithumb-bot/data
# LOG_ROOT=/var/lib/bithumb-bot/logs
# BACKUP_ROOT=/var/lib/bithumb-bot/backup
# DB_PATH=/var/lib/bithumb-bot/data/live/trades/live.sqlite
# NOTIFIER_ENABLED=true
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# MAX_ORDER_KRW=30000
# MAX_DAILY_LOSS_KRW=20000
# MAX_DAILY_ORDER_COUNT=6
# KILL_SWITCH=false
# KILL_SWITCH_LIQUIDATE=false
# LIVE_DRY_RUN=true
# LIVE_REAL_ORDER_ARMED=false

# [Preset C] Live armed (real orders allowed only with explicit arming)
# 1) Operator confirmation: "LIVE real-order arming approved"
# 2) Set both values immediately before run:
# LIVE_DRY_RUN=false
# LIVE_REAL_ORDER_ARMED=true
