# Core runtime
MODE=paper
ENV_ROOT=/var/lib/bithumb-bot/env
RUN_ROOT=/var/lib/bithumb-bot/run
DATA_ROOT=/var/lib/bithumb-bot/data
LOG_ROOT=/var/lib/bithumb-bot/logs
BACKUP_ROOT=/var/lib/bithumb-bot/backup
# Live startup requires these runtime roots to be distinct absolute paths.
# Optional
ARCHIVE_ROOT=/var/lib/bithumb-bot/archive

# Storage contract quick map for PathManager-managed runtime roots
# - logs/<mode>/{app,strategy,orders,fills,errors,audit}
# - data/<mode>/trades/*        (append-only ledger JSONL + SQLite)
# - data/<mode>/reports/*       (ops/validation/diagnostics/recovery JSON)
# - data/<mode>/derived/*       (analysis/trace/tuning artifacts)
# - data/<mode>/raw/*           (future API raw response archives)

# Canonical market symbol. Internal canonical is always KRW-BTC.
# In MODE=live, MARKET and PAIR must both resolve to canonical KRW-BTC.
# Legacy alias input (PAIR=BTC_KRW, PAIR=BTC) is only allowed in paper mode or the live dry-run posture.
MARKET=KRW-BTC
# PAIR=BTC_KRW

# Market registry cache safety (seconds).
# - 0: always refetch
# - >0: reuse the in-memory TTL cache
# - Live preflight default: force refresh once at startup unless overridden
MARKET_REGISTRY_CACHE_TTL_SEC=900
MARKET_PREFLIGHT_FORCE_REGISTRY_REFRESH=
INTERVAL=1m
EVERY=60

# Strategy selection
# - The default strategy is `sma_with_filter`.
# - If you need to override it, set `STRATEGY_NAME` explicitly.
# - Keep `STRATEGY_NAME` values stable and whitespace-free.
STRATEGY_NAME=sma_with_filter
SMA_SHORT=7
SMA_LONG=30
SMA_FILTER_GAP_MIN_RATIO=0.0012
SMA_FILTER_VOL_WINDOW=10
SMA_FILTER_VOL_MIN_RANGE_RATIO=0.003
SMA_FILTER_OVEREXT_LOOKBACK=3
SMA_FILTER_OVEREXT_MAX_RETURN_RATIO=0.02

# sma_with_filter cost-edge gate.
# - true: block BUY/SELL signals when cost_edge is not met
# - false: disable the cost-edge gate and let the other filters decide
SMA_COST_EDGE_ENABLED=true
# Minimum expected edge ratio. If unset, the fallback uses STRATEGY_MIN_EXPECTED_EDGE_RATIO.
SMA_COST_EDGE_MIN_RATIO=0
ENTRY_EDGE_BUFFER_RATIO=0.0005
STRATEGY_MIN_EXPECTED_EDGE_RATIO=0
STRATEGY_EXIT_RULES=opposite_cross,max_holding_time
STRATEGY_EXIT_MAX_HOLDING_MIN=0

# Profit-take buffer. Use environment-specific overrides only.
# The default value is intentionally conservative.
STRATEGY_EXIT_MIN_TAKE_PROFIT_RATIO=0
# Zero means the min-profit floor fallback is active.
STRATEGY_EXIT_SMALL_LOSS_TOLERANCE_RATIO=0

# Compatibility override (optional):
# - Use `DATA_ROOT/<mode>/trades/<mode>.sqlite` by default.
# - If set, use an absolute path only.
# - In MODE=live, the path must be repository-external and must not contain a paper segment.
DB_PATH=

# Compatibility override (optional):
# - Use `RUN_ROOT/<mode>/bithumb-bot.lock` by default.
# - In MODE=live, the path must be absolute, repository-external, and mode-correct.
RUN_LOCK_PATH=

# Compatibility override (optional):
# - Use `BACKUP_ROOT/<mode>/snapshots` by default.
# - In MODE=live, the path must be absolute, repository-external, and mode-correct.
SNAPSHOT_ROOT=

# Notifier (set at least one)
NOTIFIER_ENABLED=true
NOTIFIER_TIMEOUT_SEC=5
NOTIFIER_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Healthcheck thresholds
HEALTH_MAX_CANDLE_AGE_SEC=180
HEALTH_MAX_ERROR_COUNT=3

# Backup policy
# - `BACKUP_DIR` is the DB backup output path compatibility override.
# - Use `BACKUP_ROOT/<mode>/db` by default.
# - In MODE=live, the path must be absolute, repository-external, and mode-correct.
BACKUP_DIR=
BACKUP_RETENTION_DAYS=7
BACKUP_RETENTION_COUNT=30

# Trading risk limits (required in live mode; must be > 0)
# Conservative profile for a small 1,000,000 KRW account:
# - MAX_ORDER_KRW: 30,000 per order
# - MAX_DAILY_LOSS_KRW: 20,000 daily loss cap
# - MAX_DAILY_ORDER_COUNT: 6 order limit
MAX_ORDER_KRW=30000
MAX_DAILY_LOSS_KRW=20000
MAX_DAILY_ORDER_COUNT=6

# Emergency stop switches
KILL_SWITCH=false
# Keep false for normal operation.
# If true, kill-switch handling also attempts position flattening.
# This setting alone does not fail live preflight.
KILL_SWITCH_LIQUIDATE=false

# Live execution safety
# `LIVE_DRY_RUN=true` keeps MODE=live on the safety-gated live dry-run posture during bring-up and post-change validation.
LIVE_DRY_RUN=true
LIVE_SUBMIT_CONTRACT_PROFILE=live_explicit_submit_plan_v1
BITHUMB_API_KEY=
BITHUMB_API_SECRET=
# Private API throttles are conservative by default.
# - BITHUMB_PRIVATE_RPS_LIMIT: general private read/write traffic
# - BITHUMB_ORDER_RPS_LIMIT: order/list/lookup traffic
BITHUMB_PRIVATE_RPS_LIMIT=120
BITHUMB_ORDER_RPS_LIMIT=8
# Cancel retries are bounded and only used for transient states such as order_not_ready.
BITHUMB_CANCEL_RETRY_ATTEMPTS=3
BITHUMB_CANCEL_RETRY_BACKOFF_SEC=0.15
# Optional balance source opt-in (default off: keep the /v1/accounts snapshot path)
BITHUMB_WS_MYASSET_ENABLED=false
BITHUMB_WS_MYASSET_STALE_AFTER_MS=15000
BITHUMB_WS_MYASSET_RECV_TIMEOUT_SEC=5
# Optional BUY price=None compatibility gate.
# Keep false for the default fail-closed posture. True allows a raw /v1/orders/chance
# BUY "market" capability to resolve through the explicit compatibility alias path.
BUY_PRICE_NONE_MARKET_TO_PRICE_ALIAS_ENABLED=false
# Optional subscribe metadata (empty by default)
BITHUMB_WS_MYASSET_SUBSCRIBE_TICKET=
# Optional diagnostic switch:
# - false: no extra auth-init logging in the run loop
# - true: emit secret-safe auth/bootstrap diagnostics to journald during live run
BITHUMB_AUTH_DIAGNOSTICS=false

# Fee configuration
# - LIVE_FEE_RATE_ESTIMATE: degraded-mode fee estimate only when chance-derived fee authority is unavailable
# - PAPER_FEE_RATE: paper fill and PnL fee rate
# - In normal live execution, /v1/orders/chance bid_fee/ask_fee/maker fees are the canonical fee authority
# - Strategy edge calculations combine canonical fee authority, STRATEGY_ENTRY_SLIPPAGE_BPS, and ENTRY_EDGE_BUFFER_RATIO
# - sma_with_filter can gate cost edge with SMA_COST_EDGE_ENABLED / SMA_COST_EDGE_MIN_RATIO
# - SMA_COST_EDGE_MIN_RATIO falls back to STRATEGY_MIN_EXPECTED_EDGE_RATIO when unset
# Resolution order:
# - If chance-derived fee authority is unavailable, LIVE_FEE_RATE_ESTIMATE may be used only as an explicit degraded estimate
# - If LIVE_FEE_RATE_ESTIMATE is unset, use FEE_RATE -> 0.0025
# - If PAPER_FEE_RATE is unset, use PAPER_FEE_RATE_ESTIMATE -> FEE_RATE -> LIVE_FEE_RATE_ESTIMATE -> 0.0025
# - Keep this aligned with the observed Bithumb paid-fee baseline for your account tier; coherent exchange paid_fee
#   remains settlement authority, but planning and diagnostics still depend on the configured estimate.
LIVE_FEE_RATE_ESTIMATE=0.0004
PAPER_FEE_RATE=0.0025

# Live orderbook / market slippage protections
# In MODE=live, set both to finite values > 0.
MAX_ORDERBOOK_SPREAD_BPS=0
MAX_MARKET_SLIPPAGE_BPS=0
# Strategy entry slippage buffer in basis points.
# If unset, the code resolves MAX_MARKET_SLIPPAGE_BPS -> SLIPPAGE_BPS -> 0.
STRATEGY_ENTRY_SLIPPAGE_BPS=0

# Additional live price protection.
# The template default is 0, but MODE=live must set
# LIVE_PRICE_PROTECTION_MAX_SLIPPAGE_BPS to a finite value > 0.
# - blocks BUY if best ask is above the reference plus the slippage threshold
# - blocks SELL if best bid is below the reference minus the slippage threshold
# - when LIVE_PRICE_REFERENCE_MAX_AGE_SEC > 0, stale or unknown reference age blocks submission
LIVE_PRICE_PROTECTION_MAX_SLIPPAGE_BPS=0
LIVE_PRICE_REFERENCE_MAX_AGE_SEC=0

# Optional live order quantity normalization (safe no-op defaults)
# - Applied by flooring only. Never rounds up.
LIVE_MIN_ORDER_QTY=0
LIVE_ORDER_QTY_STEP=0
LIVE_ORDER_MAX_QTY_DECIMALS=0

# Residual inventory policy:
# - `block`: fail closed and require residual policy review
# - `track`: treat explainable converged residual inventory as tracked exposure
# - `ignore_tiny`: only non-sellable tiny dust may be treated as effective-flat/tracked-only
RESIDUAL_INVENTORY_MODE=block
# Residual closeout execution policy. Default is telemetry-only.
# - telemetry: build candidate/proof/plan telemetry; never submit residual SELL
# - dry_run: build a residual submit plan; do not send a broker order
# - enabled: permit residual SELL only when proof passes, live is armed, and LIVE_DRY_RUN=false
RESIDUAL_LIVE_SELL_MODE=telemetry
# Residual-aware BUY sizing policy. Default is telemetry-only.
# - off: existing BUY sizing behavior
# - telemetry: compute target/current/delta telemetry; do not alter submit sizing
# - delta: submit only target exposure minus tracked residual exposure
RESIDUAL_BUY_SIZING_MODE=telemetry

# ------------------------------------------------------------
# Conservative preset examples (small-account, safety-first)
# Copy one block into your runtime env file and adjust webhook/API values.
# Keep paper/live DB paths separate to avoid ledger mixing.
# ------------------------------------------------------------

# [Preset A] Paper validation (recommended first step)
# MODE=paper
# ENV_ROOT=/var/lib/bithumb-bot/env
# RUN_ROOT=/var/lib/bithumb-bot/run
# DATA_ROOT=/var/lib/bithumb-bot/data
# LOG_ROOT=/var/lib/bithumb-bot/logs
# BACKUP_ROOT=/var/lib/bithumb-bot/backup
# DB_PATH=/var/lib/bithumb-bot/data/paper/trades/paper.sqlite
# NOTIFIER_ENABLED=true
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# MAX_ORDER_KRW=30000
# MAX_DAILY_LOSS_KRW=20000
# MAX_DAILY_ORDER_COUNT=6
# KILL_SWITCH=false
# KILL_SWITCH_LIQUIDATE=false
# LIVE_DRY_RUN=true

# [Preset B] Live dry-run posture (private read checks still require API credentials)
# MODE=live
# ENV_ROOT=/var/lib/bithumb-bot/env
# RUN_ROOT=/var/lib/bithumb-bot/run
# DATA_ROOT=/var/lib/bithumb-bot/data
# LOG_ROOT=/var/lib/bithumb-bot/logs
# BACKUP_ROOT=/var/lib/bithumb-bot/backup
# DB_PATH=/var/lib/bithumb-bot/data/live/trades/live.sqlite
# NOTIFIER_ENABLED=true
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# BITHUMB_API_KEY=your_api_key
# BITHUMB_API_SECRET=your_api_secret
# MAX_ORDER_KRW=30000
# MAX_DAILY_LOSS_KRW=20000
# MAX_DAILY_ORDER_COUNT=6
# MAX_ORDERBOOK_SPREAD_BPS=100
# MAX_MARKET_SLIPPAGE_BPS=50
# LIVE_PRICE_PROTECTION_MAX_SLIPPAGE_BPS=25
# KILL_SWITCH=false
# KILL_SWITCH_LIQUIDATE=false
# LIVE_DRY_RUN=true
# LIVE_REAL_ORDER_ARMED=false

# [Preset C] Live armed (real orders allowed only with explicit arming)
# 1) Operator confirmation: "LIVE real-order arming approved"
# 2) Set both values immediately before run:
# MODE=live
# DB_PATH=/var/lib/bithumb-bot/data/live/trades/live.sqlite
# NOTIFIER_ENABLED=true
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# BITHUMB_API_KEY=your_api_key
# BITHUMB_API_SECRET=your_api_secret
# MAX_ORDER_KRW=30000
# MAX_DAILY_LOSS_KRW=20000
# MAX_DAILY_ORDER_COUNT=6
# MAX_ORDERBOOK_SPREAD_BPS=100
# MAX_MARKET_SLIPPAGE_BPS=50
# LIVE_PRICE_PROTECTION_MAX_SLIPPAGE_BPS=25
# KILL_SWITCH=false
# KILL_SWITCH_LIQUIDATE=false
# LIVE_DRY_RUN=false
# LIVE_REAL_ORDER_ARMED=true
